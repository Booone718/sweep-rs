{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sweep",
  "version": "0.1.0",
  "identifier": "com.sweep.cleaner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sweep",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  }
}
